{
    "name": "next-season/next-fc2blog2wp",
    "description": "Import FC2 BLOG posts to WordPress via WP-CLI",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "NExT-Season",
            "homepage": "https://next-season.net"
        }
    ],
    "require": {
        "php": ">=8.3"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.9",
        "wp-coding-standards/wpcs": "^3.1",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "phpunit/phpunit": "^9.6",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "config": {
        "platform": {
            "php": "8.3.0"
        },
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "phpcs": "phpcs",
        "phpcbf": "phpcbf",
        "test:unit": "phpunit --testsuite unit",
        "test:integration": "phpunit --testsuite integration --bootstrap tests/phpunit/bootstrap.php"
    }
}
